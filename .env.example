# Postgres
DATABASE_URL="postgres://postgres:postgres@localhost:5432/abdimas"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
