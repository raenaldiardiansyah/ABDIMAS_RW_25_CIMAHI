# Postgres
DATABASE_URL="postgres://postgres:postgres@localhost:5432/abdimas"

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="CHANGE_ME_TO_RANDOM_32B_BASE64_OR_LONG_STRING"
# Optional but recommended for correct redirects/callbacks
BETTER_AUTH_URL="http://localhost:3000"

# Identity security
NIK_ENCRYPTION_KEY_BASE64="CHANGE_ME_32_BYTES_BASE64"
# Any long random string (server-only)
NIK_HASH_PEPPER="CHANGE_ME_LONG_RANDOM"

# Admin bootstrap (comma-separated emails)
ADMIN_EMAILS="admin@rw25.local"

