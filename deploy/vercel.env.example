# Vercel environment variables for apps/web.
# Set these in Vercel Project Settings, not in Git.

NODE_ENV=production

# Public frontend URL. Use the final production domain after it is connected.
APP_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com

# VPS backend public URL.
# Next.js rewrites /api/platform/* to this URL.
BACKEND_URL=https://api.example.com

# Keep empty unless the browser must call the backend directly.
# Default app flow should use /api/platform through Vercel rewrites.
NEXT_PUBLIC_BACKEND_URL=

# Shared server-side values used by Next auth/server routes.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/abdimas
BETTER_AUTH_SECRET=CHANGE_ME
NIK_ENCRYPTION_KEY_BASE64=CHANGE_ME
NIK_HASH_PEPPER=CHANGE_ME
ADMIN_EMAILS=admin@example.com

# External public services
NEXT_PUBLIC_KPU_DPT_URL=https://cekdptonline.kpu.go.id/
NEXT_PUBLIC_CEK_BANSOS_URL=https://cekbansos.kemensos.go.id/
