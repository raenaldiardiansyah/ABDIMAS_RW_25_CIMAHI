# VPS backend environment variables.
# Copy to /var/www/abdimas-rw25/.env and fill real values.

NODE_ENV=production
PORT=4000

# Public API URL served by Nginx on the VPS.
BACKEND_URL=https://api.example.com

# Public Vercel frontend URL.
APP_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com
BETTER_AUTH_URL=https://app.example.com
BETTER_AUTH_TRUSTED_ORIGINS=https://app.example.com

# Database
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/abdimas

# Must match Vercel frontend values.
BETTER_AUTH_SECRET=CHANGE_ME
NIK_ENCRYPTION_KEY_BASE64=CHANGE_ME
NIK_HASH_PEPPER=CHANGE_ME
ADMIN_EMAILS=admin@example.com

# Cloudflare R2 or S3-compatible storage for uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
